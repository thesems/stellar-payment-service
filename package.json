{
  "name": "stellar-payment-service",
  "version": "0.1.0",
  "description": "Backend service for building, submitting, and tracking Stellar transactions.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently -k \"tsx watch src/server.ts\" \"vite --config web/vite.config.js\"",
    "dev:web": "vite --config web/vite.config.js",
    "worker:tx": "tsx src/worker/track-transactions.ts",
    "build:web": "vite build --config web/vite.config.js",
    "build": "npm run build:web && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:sac-create-account": "tsx src/scripts/sac-create-g-account.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "keywords": [
    "stellar",
    "horizon",
    "transactions"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^13.3.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  }
}
